{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5174",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true,
        "execute": true,
        "sidecar": true,
        "scope": [
          {
            "name": "binaries/python",
            "cmd": "python",
            "args": true
          }
        ]
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://**", "https://**"]
      },
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "createDir": true,
        "scope": ["$APP/**", "$TEMP/**"]
      },
      "notification": {
        "all": true
      },
      "window": {
        "all": false,
        "create": true,
        "close": true,
        "hide": true,
        "show": true,
        "setFocus": true,
        "setAlwaysOnTop": true,
        "setSize": true,
        "setPosition": true,
        "startDragging": true,
        "setDecorations": true
      },
      "globalShortcut": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Utility",
      "copyright": "",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.kuaizai.app",
      "shortDescription": "分布式AI游戏助手",
      "longDescription": "基于大模型的游戏AI助手，通过截图分析游戏画面，提供实时指导。支持悬浮窗模式、全局快捷键、语音播报等功能。",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "wix": {
          "language": "zh-CN"
        }
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBMjYyMEZCRTI1NjE4MzMKUldRQlB1ZWJpK1RXRGhvbTM0aEZ6MCtUek1veUJVYUJkclJqT1o5YlFkMlRGM3NLZEQ2RVlGYUsK",
      "endpoints": [
        "https://releases.kuaizai-os.com/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "basicUi"
      }
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "KUAIZAI_OS",
        "width": 1400,
        "minWidth": 1200,
        "minHeight": 700,
        "center": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ]
  }
}
